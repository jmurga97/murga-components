{
  "name": "@murga.ing/components",
  "version": "0.1.1",
  "description": "Accessible Lit web components with optional React wrappers.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js"
    },
    "./components/*": {
      "types": "./dist/components/*/index.d.ts",
      "import": "./dist/components/*/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite",
    "lint": "bun run lint:prettier && bun run lint:eslint",
    "lint:prettier": "prettier --check .",
    "lint:eslint": "eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "check": "tsc --noEmit",
    "build": "rm -rf dist && vite build",
    "package:check": "bun run build && publint && bun pm pack --dry-run",
    "prepublishOnly": "bun run lint && bun run check && bun run package:check",
    "publish": "npm publish --access public",
    "publish:public": "bun run publish"
  },
  "peerDependencies": {
    "lit": "^3.3.1",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "ajv": "^8.20.0",
    "eslint": "^9.39.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-lit": "^2.3.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-wc": "^3.1.0",
    "globals": "^17.6.0",
    "lit": "^3.3.1",
    "prettier": "^3.6.2",
    "publint": "^0.3.15",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^7.1.12",
    "vite-plugin-dts": "^4.5.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jmurga97/murga-components.git"
  },
  "bugs": {
    "url": "https://github.com/jmurga97/murga-components/issues"
  },
  "homepage": "https://github.com/jmurga97/murga-components#readme",
  "packageManager": "bun@1.3.6",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
